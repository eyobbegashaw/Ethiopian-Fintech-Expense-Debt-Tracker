# API Configuration
API_URL=http://localhost:3000/api/v1
# For production
# API_URL=https://api.ethiodebttracker.com/api/v1

# For Android Emulator (10.0.2.2 points to localhost)
# API_URL=http://10.0.2.2:3000/api/v1

# For iOS Simulator
# API_URL=http://localhost:3000/api/v1

# For Physical Device (Replace with your computer's IP)
# API_URL=http://192.168.1.100:3000/api/v1

# App Configuration
APP_NAME=Ethio Debt Tracker
APP_VERSION=1.0.0
ENVIRONMENT=development

# Feature Flags
ENABLE_BIOMETRIC_AUTH=false
ENABLE_OFFLINE_MODE=true
ENABLE_PUSH_NOTIFICATIONS=true

# Payment Integration (Mock for MVP)
TELEBIRR_USSD_CODE=*899#
CBE_USSD_CODE=*847#
AMOLE_USSD_CODE=*850#

# Analytics (Optional)
ENABLE_ANALYTICS=false
SENTRY_DSN=

# Store URLs
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.ethiodebttracker.app
APP_STORE_URL=https://apps.apple.com/app/ethio-debt-tracker/id123456789

# Support Contact
SUPPORT_EMAIL=support@ethiodebttracker.com
SUPPORT_PHONE=+251911111111

# Social Links
WEBSITE_URL=https://ethiodebttracker.com
PRIVACY_POLICY_URL=https://ethiodebttracker.com/privacy
TERMS_URL=https://ethiodebttracker.com/terms

# Deep Linking
DEEP_LINK_SCHEME=ethiodebttracker://
DEEP_LINK_HOST=app.ethiodebttracker.com

# Cache Configuration
CACHE_TTL=3600000
MAX_CACHE_SIZE=50

# Image Upload
MAX_IMAGE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg

# Timeout Configuration
API_TIMEOUT=30000
SOCKET_TIMEOUT=60000

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY=1000

# Logging
LOG_LEVEL=debug
ENABLE_CONSOLE_LOGS=true